{
  "manifest_version": 3,
  "name": "Notion Turbo — Long Chat Optimizer",
  "version": "1.0.4",
  "minimum_chrome_version": "111",
  "description": "Keeps long Notion AI chats fast: reduces lag in large conversations so they stay smooth, responsive, and quick to load.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.notion.com/*"
  ],
  "content_scripts": [
    {
      "js": [
        "page.js"
      ],
      "matches": [
        "https://*.notion.com/*"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "js": [
        "content.js"
      ],
      "matches": [
        "https://*.notion.com/*"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Notion Turbo",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
